// Navigation Data panel — position, marker, heading, distance, height diff, bearing.

import { IconSet } from "@lucide";
import { Theme } from "../../../common/theme.slint";
import { PanelCard, PanelContent, PanelHeader, NavRow } from "../../../common/widgets.slint";

export component DataPanel inherits PanelCard {
    in property <string> position-text: "Waiting...";
    in property <string> marker-text: "No marker detected";
    in property <bool>   marker-detected: false;
    in property <string> heading-text: "--";
    in property <string> distance-text: "0.0 m";
    in property <string> height-diff-text: "0.0 m";
    in property <string> bearing-text: "0.0°";

    callback copy-position();
    callback input-marker();
    callback copy-marker();
    callback paste-marker();
    callback save-position();
    callback save-marker();

    VerticalLayout {
        padding: 0; spacing: 0;
        PanelHeader { icon: IconSet.Braces; title: "DATA"; }
        PanelContent {
            row-spacing: 0;
            NavRow { icon: IconSet.LocateFixed; label: "POSITION"; value: root.position-text;
                copyable: true; copy-clicked => { root.copy-position(); }
                saveable: true; save-clicked => { root.save-position(); }
            }
            NavRow {
                icon: IconSet.MapPin; label: "MARKER DEST.";
                value: root.marker-text;
                value-color: root.marker-detected ? Theme.teal : #C8962C;
                inputable: true; input-clicked => { root.input-marker(); }
                copyable: true; copy-clicked => { root.copy-marker(); }
                pasteable: true; paste-clicked => { root.paste-marker(); }
                saveable: true; save-clicked => { root.save-marker(); }
            }
            NavRow { icon: IconSet.Move3d;              label: "HEADING";      value: root.heading-text; }
            NavRow { icon: IconSet.RulerDimensionLine; label: "DISTANCE";     value: root.distance-text; }
            NavRow { icon: IconSet.Mountain;            label: "HEIGHT DIFF."; value: root.height-diff-text; }
            NavRow { icon: IconSet.Navigation;          label: "BEARING";      value: root.bearing-text; }
        }
    }
}
