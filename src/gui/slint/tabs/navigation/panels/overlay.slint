// Overlay panel — opacity, scale, and lock toggle.

import { IconDisplay, IconSet } from "@lucide";
import { Theme } from "../../../common/theme.slint";
import { PanelCard, PanelContent, IconBadge, SliderCard } from "../../../common/widgets.slint";

export component OverlayPanel inherits PanelCard {
    in-out property <float> ov-opacity: 0.5;
    in-out property <float> scale: 1.0;
    in-out property <bool>  locked: true;

    in property <string> ov-opacity-label: "50%";
    in property <string> scale-label: "1.00x";

    callback lock-toggled();
    callback ov-opacity-changed(float);
    callback scale-changed(float);

    VerticalLayout {
        padding: 0; spacing: 0;

        // Header with inline lock button
        Rectangle {
            height: 44px;
            HorizontalLayout {
                padding-left: 12px; padding-right: 10px;
                spacing: 6px;
                Rectangle {
                    width: 38px; horizontal-stretch: 0;
                    IconBadge {
                        x: 0; y: (parent.height - 38px) / 2;
                        icon: IconSet.Eye; badge-size: 38px;
                    }
                }
                Text {
                    text: "OVERLAY"; color: Theme.teal;
                    font-size: 18px; font-weight: 700;
                    vertical-alignment: center; letter-spacing: 1.5px;
                    horizontal-stretch: 0;
                }
                Rectangle { horizontal-stretch: 1; }
                ov-lock-ta := TouchArea {
                    width: 100px; horizontal-stretch: 0;
                    clicked => { root.lock-toggled(); }
                    Rectangle {
                        y: (parent.height - 28px) / 2; height: 28px;
                        border-radius: 5px;
                        background: root.locked
                            ? (ov-lock-ta.pressed ? #2a0808 : ov-lock-ta.has-hover ? #2e1010 : Theme.error-bg)
                            : (ov-lock-ta.pressed ? #162628 : ov-lock-ta.has-hover ? #1e3032 : #192E32);
                        border-color: root.locked ? Theme.error-border : #2A8090;
                        border-width: 1px;
                        HorizontalLayout {
                            alignment: center; spacing: 5px;
                            Rectangle {
                                width: 14px;
                                IconDisplay {
                                    y: (parent.height - 14px) / 2;
                                    icon: root.locked ? IconSet.Lock : IconSet.LockOpen;
                                    size: 14px;
                                    stroke: root.locked ? Theme.error-text : Theme.teal-accent;
                                    stroke-width: 1.5; absolute-stroke-width: true;
                                }
                            }
                            Text {
                                text: root.locked ? "LOCKED" : "UNLOCKED";
                                color: root.locked ? Theme.error-text : Theme.teal-accent;
                                font-size: 11px; font-weight: 700;
                                vertical-alignment: center;
                                letter-spacing: 0.8px;
                            }
                        }
                    }
                }
            }
        }

        PanelContent {
            SliderCard {
                label: "OPACITY"; value: root.ov-opacity;
                minimum: 0.1; maximum: 1.0;
                value-label: root.ov-opacity-label;
                icon: IconSet.Blend; show-icon: true;
                value-changed(v) => { root.ov-opacity-changed(v); }
            }
            SliderCard {
                label: "SCALE"; value: root.scale;
                minimum: 0.5; maximum: 2.5;
                value-label: root.scale-label;
                icon: IconSet.ImageUpscale; show-icon: true;
                value-changed(v) => { root.scale-changed(v); }
            }
        }
    }
}
