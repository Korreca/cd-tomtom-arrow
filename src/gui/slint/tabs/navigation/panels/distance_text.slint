// Distance Text panel — text offset X/Y and text size scale.

import { IconSet } from "@lucide";
import { Theme } from "../../../common/theme.slint";
import { PanelCard, PanelContent, PanelHeader, CtrlRow, CtrlIcon, TomSpin, TomSlider } from "../../../common/widgets.slint";

export component DistanceTextPanel inherits PanelCard {
    bg: #202123;

    in-out property <int>   text-offset-x: 0;
    in-out property <int>   text-offset-y: 0;
    in-out property <float> text-scale: 1.0;

    in property <string> text-scale-label: "1.00x";

    callback text-offset-x-changed(int);
    callback text-offset-y-changed(int);
    callback text-scale-changed(float);

    VerticalLayout {
        padding: 0; spacing: 0;
        PanelHeader { icon: IconSet.CaseSensitive; title: "DISTANCE TEXT"; }
        PanelContent {
            CtrlRow {
                CtrlIcon { icon: IconSet.MoveHorizontal; }
                Text {
                    text: "OFFSET X";
                    color: Theme.label; font-size: 14px; font-weight: 700;
                    vertical-alignment: center; width: 76px;
                    letter-spacing: 0.2px;
                }
                VerticalLayout {
                    alignment: center; horizontal-stretch: 0;
                    TomSpin {
                        value: root.text-offset-x; minimum: -200;
                        maximum: 200; step: 1;
                        value-changed(v) => { root.text-offset-x-changed(v); }
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                CtrlIcon { icon: IconSet.MoveVertical; }
                Text {
                    text: "OFFSET Y";
                    color: Theme.label; font-size: 14px; font-weight: 700;
                    vertical-alignment: center; width: 76px;
                    letter-spacing: 0.2px;
                }
                VerticalLayout {
                    alignment: center; horizontal-stretch: 0;
                    TomSpin {
                        value: root.text-offset-y; minimum: -200;
                        maximum: 200; step: 1;
                        value-changed(v) => { root.text-offset-y-changed(v); }
                    }
                }
            }
            CtrlRow {
                CtrlIcon { icon: IconSet.MoveDiagonal; }
                Text {
                    text: "TEXT SIZE";
                    color: Theme.label; font-size: 14px; font-weight: 700;
                    vertical-alignment: center; width: 84px;
                    letter-spacing: 0.2px;
                }
                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    TomSlider {
                        value: root.text-scale;
                        minimum: 0.5; maximum: 2.5;
                        value-changed(v) => { root.text-scale-changed(v); }
                    }
                }
                Text {
                    text: root.text-scale-label; color: Theme.label;
                    font-size: 15px; font-weight: 700;
                    width: 52px; horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }
    }
}
