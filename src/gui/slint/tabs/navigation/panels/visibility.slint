// Visibility panel — auto-hide distance and inactivity timeout controls.

import { IconSet } from "@lucide";
import { Theme } from "../../../common/theme.slint";
import { PanelCard, PanelContent, PanelHeader, CtrlRow, CtrlIcon, TomSpin, TomCheck } from "../../../common/widgets.slint";

export component VisibilityPanel inherits PanelCard {
    bg: #1e2022;

    in-out property <int>  hide-below: 10;
    in-out property <bool> sticky-hide: true;
    in-out property <int>  inactive-ms: 1200;
    in-out property <bool> hide-on-inactive: true;

    callback hide-below-changed(int);
    callback sticky-hide-changed(bool);
    callback inactive-ms-changed(int);
    callback hide-on-inactive-changed(bool);

    VerticalLayout {
        padding: 0; spacing: 0;
        PanelHeader { icon: IconSet.EyeOff; title: "VISIBILITY"; }
        PanelContent {
            bg: #191a1c;
            CtrlRow {
                CtrlIcon { icon: IconSet.MapPinOff; }
                Text {
                    text: "AUTO-HIDE (m)";
                    color: Theme.label; font-size: 14px; font-weight: 700;
                    vertical-alignment: center; width: 118px;
                    letter-spacing: 0.2px;
                }
                VerticalLayout {
                    alignment: center; horizontal-stretch: 0;
                    TomSpin {
                        value: root.hide-below; minimum: 0;
                        maximum: 500; step: 1;
                        value-changed(v) => { root.hide-below-changed(v); }
                    }
                }
                VerticalLayout {
                    alignment: center; horizontal-stretch: 0;
                    TomCheck {
                        label: "STICKY-HIDE";
                        checked: root.sticky-hide;
                        toggled(v) => { root.sticky-hide-changed(v); }
                    }
                }
            }
            CtrlRow {
                CtrlIcon { icon: IconSet.TimerOff; }
                Text {
                    text: "INACTIVITY (ms)";
                    color: Theme.label; font-size: 14px; font-weight: 700;
                    vertical-alignment: center; width: 118px;
                    letter-spacing: 0.2px;
                }
                VerticalLayout {
                    alignment: center; horizontal-stretch: 0;
                    TomSpin {
                        value: root.inactive-ms; minimum: 0;
                        maximum: 10000; step: 100;
                        value-changed(v) => { root.inactive-ms-changed(v); }
                    }
                }
                VerticalLayout {
                    alignment: center; horizontal-stretch: 0;
                    TomCheck {
                        label: "HIDE WHEN INACTIVE";
                        checked: root.hide-on-inactive;
                        toggled(v) => { root.hide-on-inactive-changed(v); }
                    }
                }
            }
        }
    }
}
