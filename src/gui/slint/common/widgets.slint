// Shared widget primitives and reusable components.

import { IconDisplay, IconSet, Icon } from "@lucide";
import { Theme } from "./theme.slint";

// --- Panel card (outer frame shared by all panels) ---------------------------
// Override `bg` when a panel uses a slightly different background shade.
export component PanelCard inherits Rectangle {
    in property <color> bg: Theme.window-bg;
    width: 580px; horizontal-stretch: 0; vertical-stretch: 0;
    background: root.bg;
    border-color: Theme.panel-border; border-width: 1px; border-radius: 8px;
}

// --- Panel content (padded wrapper + shaded inner rect) ----------------------
// @children land inside the innermost VerticalLayout.
// Override `bg` or `row-spacing` when a panel differs from the defaults.
export component PanelContent inherits VerticalLayout {
    in property <color> bg: Theme.inner-bg;
    in property <length> row-spacing: 2px;
    padding-left: 10px; padding-right: 10px;
    padding-top: 0; padding-bottom: 10px; spacing: 0;
    Rectangle {
        background: root.bg; border-radius: 6px;
        border-color: Theme.inner-border; border-width: 1px;
        VerticalLayout {
            padding: 6px; spacing: root.row-spacing;
            @children
        }
    }
}

// --- Small icon inside a CtrlRow (20 px wide, muted stroke) ------------------
export component CtrlIcon {
    in property <Icon> icon: IconSet.Circle;
    width: 20px;
    IconDisplay {
        x: 2px; y: (parent.height - 16px) / 2;
        icon: root.icon; stroke: Theme.icon-muted;
        size: 16px; stroke-width: 1.5; absolute-stroke-width: true;
    }
}

// --- Placeholder for tabs not yet implemented --------------------------------
export component ComingSoon inherits Rectangle {
    horizontal-stretch: 1; vertical-stretch: 1;
    Text {
        text: "Coming soon..."; color: #3a4050; font-size: 28px; font-weight: 700;
        horizontal-alignment: center; vertical-alignment: center; letter-spacing: 1px;
    }
}

// --- Slider ------------------------------------------------------------------
export component TomSlider inherits Rectangle {
    in-out property <float> value: 0.5;
    in property <float> minimum: 0.0;
    in property <float> maximum: 1.0;
    callback value-changed(float);

    preferred-width: 100%;
    height: 24px;
    property <float> ratio: clamp(
        (root.value - root.minimum) / (root.maximum - root.minimum), 0.0, 1.0);

    // Track background
    Rectangle {
        x: 10px; y: parent.height / 2 - self.height / 2;
        width: parent.width - 20px; height: 4px;
        background: #2c3438; border-radius: 2px;
    }
    // Track fill
    Rectangle {
        x: 10px; y: parent.height / 2 - self.height / 2;
        width: root.ratio * (parent.width - 20px); height: 4px;
        background: Theme.teal; border-radius: 2px;
    }
    // Handle
    Rectangle {
        x: 10px + root.ratio * (parent.width - 30px);
        y: parent.height / 2 - self.height / 2;
        width: 16px; height: 16px; border-radius: 8px;
        background: ta.pressed ? Theme.teal-hover : Theme.teal;
        border-color: Theme.teal-dark; border-width: 1.5px;
    }
    ta := TouchArea {
        moved => {
            if self.pressed {
                root.value = clamp(
                    root.minimum + ((self.mouse-x - 10px) / (parent.width - 20px))
                        * (root.maximum - root.minimum),
                    root.minimum, root.maximum);
                root.value-changed(root.value);
            }
        }
        pointer-event(e) => {
            if e.kind == PointerEventKind.down {
                root.value = clamp(
                    root.minimum + ((self.mouse-x - 10px) / (parent.width - 20px))
                        * (root.maximum - root.minimum),
                    root.minimum, root.maximum);
                root.value-changed(root.value);
            }
        }
    }
}

// --- Integer spinbox ---------------------------------------------------------
export component TomSpin {
    in-out property <int> value: 0;
    in property <int> minimum: 0;
    in property <int> maximum: 9999;
    in property <int> step: 1;
    callback value-changed(int);

    width: 120px; height: 36px;

    property <int> _dir: 0;  // -1 = minus held, +1 = plus held

    // Initial hold delay before rapid repeat starts (~400 ms)
    delay-timer := Timer {
        interval: 400ms;
        running: false;
        triggered => {
            delay-timer.running = false;
            repeat-timer.running = true;
        }
    }

    // Rapid repeat fired while button is held
    repeat-timer := Timer {
        interval: 80ms;
        running: false;
        triggered => {
            if root._dir < 0 {
                if root.value - root.step >= root.minimum {
                    root.value -= root.step;
                    root.value-changed(root.value);
                }
            } else if root._dir > 0 {
                if root.value + root.step <= root.maximum {
                    root.value += root.step;
                    root.value-changed(root.value);
                }
            }
        }
    }

    // Single outer shell — one border, clipped corners
    Rectangle {
        border-radius: 5px; border-width: 1px; border-color: Theme.btn-border;
        background: Theme.spin-bg; clip: true;

        HorizontalLayout {
            spacing: 0; padding: 0;

            // Minus button
            dn-ta := TouchArea {
                width: 32px;
                pointer-event(e) => {
                    if e.kind == PointerEventKind.down {
                        if root.value - root.step >= root.minimum {
                            root.value -= root.step;
                            root.value-changed(root.value);
                        }
                        root._dir = -1;
                        delay-timer.running = true;
                    } else if e.kind == PointerEventKind.up || e.kind == PointerEventKind.cancel {
                        delay-timer.running = false;
                        repeat-timer.running = false;
                        root._dir = 0;
                    }
                }
                Rectangle {
                    background: dn-ta.pressed ? Theme.btn-press
                        : (dn-ta.has-hover ? Theme.btn-hover : Theme.btn-bg);
                    Text {
                        text: "−"; color: Theme.teal;
                        font-size: 20px; font-weight: 300;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }
            }

            // Separator
            Rectangle { width: 1px; background: Theme.btn-border; }

            // Value display
            Rectangle {
                horizontal-stretch: 1;
                background: Theme.spin-bg;
                Text {
                    text: root.value; color: Theme.value;
                    font-size: 15px; font-weight: 700;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }

            // Separator
            Rectangle { width: 1px; background: Theme.btn-border; }

            // Plus button
            up-ta := TouchArea {
                width: 32px;
                pointer-event(e) => {
                    if e.kind == PointerEventKind.down {
                        if root.value + root.step <= root.maximum {
                            root.value += root.step;
                            root.value-changed(root.value);
                        }
                        root._dir = 1;
                        delay-timer.running = true;
                    } else if e.kind == PointerEventKind.up || e.kind == PointerEventKind.cancel {
                        delay-timer.running = false;
                        repeat-timer.running = false;
                        root._dir = 0;
                    }
                }
                Rectangle {
                    background: up-ta.pressed ? Theme.btn-press
                        : (up-ta.has-hover ? Theme.btn-hover : Theme.btn-bg);
                    Text {
                        text: "+"; color: Theme.teal;
                        font-size: 18px; font-weight: 400;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }
            }
        }
    }
}

// --- Toggle switch -----------------------------------------------------------
export component TomCheck {
    in-out property <bool> checked: false;
    in property <string> label: "";
    callback toggled(bool);

    height: 28px;
    ta := TouchArea {
        clicked => { root.checked = !root.checked; root.toggled(root.checked); }
    }
    HorizontalLayout {
        spacing: 8px; alignment: start;
        // Track
        Rectangle {
            y: (parent.height - 18px) / 2;
            width: 34px; height: 18px; border-radius: 9px;
            background: root.checked ? Theme.teal : #252729;
            border-color: root.checked ? Theme.teal-dark : #1e2022;
            border-width: 1px;
            animate background { duration: 120ms; }
            // Knob
            Rectangle {
                x: root.checked ? parent.width - 16px : 2px;
                y: 2px;
                width: 14px; height: 14px; border-radius: 7px;
                background: root.checked ? #0e1f20 : #5a6070;
                animate x { duration: 120ms; easing: ease-in-out; }
            }
        }
        Text {
            text: root.label; color: Theme.label; font-size: 13px; font-weight: 700;
            vertical-alignment: center; letter-spacing: 0.3px;
        }
    }
}

// --- Icon badge (plain Lucide icon, no circle) ------------------------------
export component IconBadge {
    in property <Icon> icon: IconSet.Circle;
    in property <length> badge-size: 28px;
    in property <color> fg: Theme.teal;

    width: root.badge-size; height: root.badge-size;

    IconDisplay {
        x: (root.badge-size - self.width) / 2;
        y: (root.badge-size - self.height) / 2;
        icon: root.icon;
        stroke: root.fg;
        size: root.badge-size * 0.68;
        stroke-width: 1.5;
        absolute-stroke-width: true;
    }
}

// --- Text badge ("Tt" plain, no circle) -------------------------------------
export component TtBadge {
    in property <length> badge-size: 28px;
    in property <color> fg: Theme.teal;

    width: root.badge-size; height: root.badge-size;

    Text {
        text: "Tt"; color: root.fg;
        font-size: 12px; font-weight: 700;
        horizontal-alignment: center; vertical-alignment: center;
    }
}

// --- Panel header (icon badge + title) ---------------------------------------
export component PanelHeader {
    in property <Icon> icon: IconSet.Circle;
    in property <bool>  use-tt: false;
    in property <string> title: "";
    in property <bool>   title-italic: false;
    height: 44px;

    HorizontalLayout {
        padding-left: 12px; padding-top: 0; padding-bottom: 0;
        spacing: 6px; alignment: start;
        // Wrapper stretches to full row height so badge is absolutely centred
        Rectangle {
            width: 38px;
            if !root.use-tt : IconBadge {
                x: 0; y: (parent.height - 38px) / 2;
                icon: root.icon; badge-size: 38px;
            }
            if root.use-tt : TtBadge {
                x: 0; y: (parent.height - 38px) / 2;
                badge-size: 38px;
            }
        }
        Text {
            text: root.title; color: Theme.teal;
            font-size: 18px; font-weight: 700;
            font-italic: root.title-italic;
            vertical-alignment: center; letter-spacing: 1.5px;
        }
        Rectangle { horizontal-stretch: 1; }
    }
}

// --- Navigation row ----------------------------------------------------------
export component NavRow {
    in property <Icon> icon: IconSet.Circle;
    in property <string> label: "";
    in property <string> value: "";
    in property <color> value-color: Theme.teal;
    in property <bool> inputable: false;
    in property <bool> copyable: false;
    in property <bool> pasteable: false;
    in property <bool> saveable: false;
    callback input-clicked();
    callback copy-clicked();
    callback paste-clicked();
    callback save-clicked();
    height: 49px;

    Rectangle {
        y: 2px; height: parent.height - 4px;
        border-radius: 6px; border-width: 1px; border-color: Theme.row-border;
        background: transparent; clip: true;
        HorizontalLayout {
            padding-left: 4px; padding-right: (root.inputable ? 22px : 0px) + (root.copyable ? 22px : 0px) + (root.pasteable ? 22px : 0px) + (root.saveable ? 22px : 0px) + 12px;
            spacing: 0; alignment: start;
            // Plain icon — no circle, muted color
            Rectangle {
                width: 22px;
                IconDisplay {
                    x: (22px - 16px) / 2;
                    y: (parent.height - 16px) / 2;
                    icon: root.icon; stroke: Theme.icon-muted;
                    size: 16px; stroke-width: 1.5; absolute-stroke-width: true;
                }
            }
            Rectangle { width: 10px; }
            Text {
                text: root.label; color: Theme.label;
                font-size: 14px; font-weight: 700;
                width: 112px; vertical-alignment: center; letter-spacing: 0.3px;
            }
            Rectangle { width: 1px; horizontal-stretch: 0;
                Rectangle { y: (parent.height - 28px) / 2; width: 1px; height: 28px; background: #252729; }
            }
            Rectangle { width: 10px; }
            Text {
                horizontal-stretch: 1;
                text: root.value; color: root.value-color;
                font-size: 15px; vertical-alignment: center;
            }
        }
        if root.inputable : input-ta := TouchArea {
            x: parent.width - (root.saveable ? 22px : 0px) - (root.copyable ? 22px : 0px) - (root.pasteable ? 44px : 22px); y: 0;
            width: 22px; height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.input-clicked(); }
            IconDisplay {
                x: (parent.width - 15px) / 2;
                y: (parent.height - 15px) / 2;
                icon: IconSet.TextCursorInput;
                stroke: input-ta.has-hover ? Theme.icon-hover : Theme.label;
                size: 15px; stroke-width: 1.5; absolute-stroke-width: true;
                animate stroke { duration: 100ms; }
            }
        }
        if root.pasteable : paste-ta := TouchArea {
            x: parent.width - (root.saveable ? 22px : 0px) - (root.copyable ? 44px : 22px); y: 0;
            width: 22px; height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.paste-clicked(); }
            IconDisplay {
                x: (parent.width - 15px) / 2;
                y: (parent.height - 15px) / 2;
                icon: IconSet.Clipboard;
                stroke: paste-ta.has-hover ? Theme.icon-hover : Theme.label;
                size: 15px; stroke-width: 1.5; absolute-stroke-width: true;
                animate stroke { duration: 100ms; }
            }
        }
        if root.copyable : copy-ta := TouchArea {
            x: parent.width - (root.saveable ? 44px : 22px); y: 0;
            width: 22px; height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.copy-clicked(); }
            IconDisplay {
                x: (parent.width - 15px) / 2;
                y: (parent.height - 15px) / 2;
                icon: IconSet.Files;
                stroke: copy-ta.has-hover ? Theme.icon-hover : Theme.label;
                size: 15px; stroke-width: 1.5; absolute-stroke-width: true;
                animate stroke { duration: 100ms; }
            }
        }
        if root.saveable : save-ta := TouchArea {
            x: parent.width - 22px; y: 0;
            width: 22px; height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.save-clicked(); }
            IconDisplay {
                x: (parent.width - 15px) / 2;
                y: (parent.height - 15px) / 2;
                icon: IconSet.Save;
                stroke: save-ta.has-hover ? Theme.icon-hover : Theme.label;
                size: 15px; stroke-width: 1.5; absolute-stroke-width: true;
                animate stroke { duration: 100ms; }
            }
        }
    }
}

// --- Control row (4 px teal left accent + @children) ------------------------
export component CtrlRow {
    height: 53px;

    Rectangle {
        y: 2px; height: parent.height - 4px;
        border-radius: 6px; border-width: 1px; border-color: Theme.row-border;
        background: transparent; clip: true;
        HorizontalLayout {
            x: 4px; y: 0; width: parent.width - 4px; height: parent.height;
            padding-right: 12px; spacing: 10px;
            @children
        }
    }
}

// --- Slider row (label + slider + value label) --------------------------------
export component SliderCard {
    in property <string> label: "";
    in property <string> value-label: "";
    in-out property <float> value: 0.5;
    in property <float> minimum: 0.0;
    in property <float> maximum: 1.0;
    in property <Icon> icon: IconSet.Circle;
    in property <bool> show-icon: false;
    callback value-changed(float);
    height: 53px;

    Rectangle {
        y: 2px; height: parent.height - 4px;
        border-radius: 6px; border-width: 1px; border-color: Theme.row-border;
        background: transparent; clip: true;
        HorizontalLayout {
            padding-left: 4px; padding-right: 14px; spacing: 12px;
            if root.show-icon : Rectangle {
                width: 20px;
                IconDisplay {
                    x: 2px; y: (parent.height - 16px) / 2;
                    icon: root.icon; stroke: Theme.icon-muted;
                    size: 16px; stroke-width: 1.5; absolute-stroke-width: true;
                }
            }
            Text {
                text: root.label; color: Theme.label;
                font-size: 14px; font-weight: 700;
                width: 70px; vertical-alignment: center; letter-spacing: 0.3px;
            }
            VerticalLayout {
                alignment: center;
                horizontal-stretch: 1;
                TomSlider {
                    value: root.value;
                    minimum: root.minimum; maximum: root.maximum;
                    value-changed(v) => { root.value-changed(v); }
                }
            }
            Text {
                text: root.value-label; color: Theme.label;
                font-size: 14px; font-weight: 700;
                width: 46px; horizontal-alignment: right; vertical-alignment: center;
            }
        }
    }
}

// --- Snackbar (top-right toast notification) ---------------------------------
// Place as an absolute-positioned direct child of the root Window.
// Parent controls x/y position; this component animates opacity on open.
export component Snackbar {
    in property <bool>   open: false;
    in property <string> message: "";
    in property <bool>   is-error: false;

    width: 280px;
    height: 44px;

    opacity: root.open ? 1.0 : 0.0;
    animate opacity { duration: 200ms; easing: ease-out; }

    Rectangle {
        background:   root.is-error ? Theme.error-bg     : Theme.success-bg;
        border-color: root.is-error ? Theme.error-border : Theme.success-border;
        border-radius: 6px;
        border-width: 1px;

        HorizontalLayout {
            padding-left: 12px; padding-right: 14px; spacing: 8px; alignment: start;
            Rectangle {
                width: 16px;
                IconDisplay {
                    y: (parent.height - 14px) / 2;
                    icon: root.is-error ? IconSet.X : IconSet.Check;
                    stroke: root.is-error ? Theme.error-text : Theme.success-text;
                    size: 14px; stroke-width: 1.5; absolute-stroke-width: true;
                }
            }
            Text {
                text: root.message;
                color: root.is-error ? Theme.error-text : Theme.success-text;
                font-size: 13px; font-weight: 700;
                vertical-alignment: center; letter-spacing: 0.3px;
            }
        }
    }
}
