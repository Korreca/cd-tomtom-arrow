// Crimson Desert TomTom — Control Panel entry point.
// Assembles title bar, tab bar, and tab content.

import { IconDisplay, IconSet } from "@lucide";
import { TitleBar }      from "./common/title_bar.slint";
import { NavigationTab, InputMarkerDialog } from "./tabs/navigation/tab_navigation.slint";
import { SettingsTab }   from "./tabs/settings/tab_settings.slint";
import { MarkersTab }    from "./tabs/markers/tab_markers.slint";
import { RoutesTab }     from "./tabs/routes/tab_routes.slint";
import { Theme } from "./common/theme.slint";
import { Snackbar } from "./common/widgets.slint";

// --- Main window -------------------------------------------------------------
export component ControlPanel inherits Window {
    title: "CD TomTom";
    no-frame: true;
    background: Theme.window-bg;
    default-font-family: "Inter";
    width: 1200px;
    height: 720px;

    // ── Data properties ───────────────────────────────────────────────────────
    in property <string> position-text: "Waiting...";
    in property <string> position-copy-text: "";
    in property <string> heading-text: "--";
    in property <string> marker-text: "No marker detected";
    in property <string> marker-copy-text: "";
    in property <bool>   marker-detected: false;
    in property <string> distance-text: "0.0 m";
    in property <string> height-diff-text: "0.0 m";
    in property <string> bearing-text: "0.0°";
    in property <bool>   connected: false;
    in property <string> status-text: "Waiting for game...";
    in property <bool>   show-reconnect: false;
    in property <string> app-version: "v 0.2.46";

    // ── Config properties ─────────────────────────────────────────────────────
    in-out property <float> ov-opacity: 0.5;
    in-out property <float> scale: 1.0;
    in-out property <float> text-scale: 1.0;
    in-out property <int>   hide-below: 10;
    in-out property <int>   inactive-ms: 1200;
    in-out property <int>   text-offset-x: 0;
    in-out property <int>   text-offset-y: 0;
    in-out property <int>   info-offset-x: 0;
    in-out property <int>   info-offset-y: 0;
    in-out property <float> info-scale: 1.0;
    in-out property <bool>  info-hidden: false;
    in-out property <bool>  sticky-hide: true;
    in-out property <bool>  hide-on-inactive: true;
    in-out property <bool>  locked: true;
    in-out property <int> active-tab: 0;

    // ── Snackbar state ────────────────────────────────────────────────────────
    in property  <int>    snack-duration-ms: Theme.snackbar-duration-ms;
    in-out property <bool>   snack-open: false;
    in-out property <string> snack-message: "";
    in-out property <bool>   snack-is-error: false;

    // ── Input Marker dialog ───────────────────────────────────────────────────
    in-out property <bool>   input-dialog-open: false;
    in-out property <string> dialog-x: "0";
    in-out property <string> dialog-y: "0";
    in-out property <string> dialog-z: "0";
    in-out property <bool>   dialog-x-error: false;
    in-out property <bool>   dialog-y-error: false;
    in-out property <bool>   dialog-z-error: false;

    // ── Formatted labels ──────────────────────────────────────────────────────
    in property <string> ov-opacity-label: "50%";
    in property <string> scale-label: "1.00x";
    in property <string> text-scale-label: "1.00x";
    in property <string> info-scale-label: "1.00x";

    // ── Callbacks ─────────────────────────────────────────────────────────────
    callback lock-toggled();
    callback ov-opacity-changed(float);
    callback scale-changed(float);
    callback text-scale-changed(float);
    callback hide-below-changed(int);
    callback inactive-ms-changed(int);
    callback text-offset-x-changed(int);
    callback text-offset-y-changed(int);
    callback info-offset-x-changed(int);
    callback info-offset-y-changed(int);
    callback info-scale-changed(float);
    callback info-hidden-changed(bool);
    callback sticky-hide-changed(bool);
    callback hide-on-inactive-changed(bool);
    callback copy-position();
    callback copy-marker();
    callback paste-marker();
    callback input-marker();
    callback save-position();
    callback save-marker();
    callback reconnect-clicked();
    callback open-kofi();
    callback open-nexus();
    callback window-close();
    callback window-minimize();
    callback title-drag-start();
    callback title-drag-delta(float, float);
    // ── Input Marker dialog callbacks ──────────────────────────────────────────
    callback input-dialog-close();
    callback input-dialog-confirm();
    callback input-dialog-paste();
    callback input-dialog-x-step(int);
    callback input-dialog-y-step(int);
    callback input-dialog-z-step(int);

    VerticalLayout {
        spacing: 0; padding: 0;

        // ── Title bar ─────────────────────────────────────────────────────────
        TitleBar {
            app-version:     root.app-version;
            window-close         => { root.window-close(); }
            window-minimize      => { root.window-minimize(); }
            title-drag-start     => { root.title-drag-start(); }
            title-drag-delta(dx, dy) => { root.title-drag-delta(dx, dy); }
        }

        // ── Content area ──────────────────────────────────────────────────────
        VerticalLayout {
            padding-left: 16px; padding-right: 16px;
            padding-top: 12px; padding-bottom: 12px;
            spacing: 12px;

            // Tab bar + status
            Rectangle {
                height: 36px;
                Rectangle { y: parent.height - 2px; height: 2px; background: #252729; }
                HorizontalLayout {
                    spacing: 8px; padding-right: 4px;

                    nav-tab := Rectangle {
                        width: 168px; horizontal-stretch: 0;
                        Rectangle { y: parent.height - 2px; height: 2px; background: root.active-tab == 0 ? Theme.teal : transparent; }
                        TouchArea { clicked => { root.active-tab = 0; } }
                        HorizontalLayout {
                            padding-left: 8px; padding-right: 12px;
                            spacing: 7px; alignment: start;
                            Rectangle {
                                width: 16px;
                                IconDisplay {
                                    y: (parent.height - 15px) / 2;
                                    icon: IconSet.Compass; stroke: root.active-tab == 0 ? Theme.teal : Theme.tab-inactive;
                                    size: 15px; stroke-width: 1.5; absolute-stroke-width: true;
                                }
                            }
                            Text {
                                text: "NAVIGATION"; color: root.active-tab == 0 ? Theme.teal : Theme.tab-inactive;
                                font-size: 13px; font-weight: 700;
                                vertical-alignment: center; letter-spacing: 0.8px;
                            }
                        }
                    }

                    markers-tab := Rectangle {
                        width: 130px; horizontal-stretch: 0;
                        Rectangle { y: parent.height - 2px; height: 2px; background: root.active-tab == 2 ? Theme.teal : transparent; }
                        TouchArea { clicked => { root.active-tab = 2; } }
                        HorizontalLayout {
                            padding-left: 8px; padding-right: 12px;
                            spacing: 7px; alignment: start;
                            Rectangle {
                                width: 16px;
                                IconDisplay {
                                    y: (parent.height - 15px) / 2;
                                    icon: IconSet.MapPinned; stroke: root.active-tab == 2 ? Theme.teal : Theme.tab-inactive;
                                    size: 15px; stroke-width: 1.5; absolute-stroke-width: true;
                                }
                            }
                            Text {
                                text: "MARKERS"; color: root.active-tab == 2 ? Theme.teal : Theme.tab-inactive;
                                font-size: 13px; font-weight: 700;
                                vertical-alignment: center; letter-spacing: 0.8px;
                            }
                        }
                    }

                    routes-tab := Rectangle {
                        width: 120px; horizontal-stretch: 0;
                        Rectangle { y: parent.height - 2px; height: 2px; background: root.active-tab == 3 ? Theme.teal : transparent; }
                        TouchArea { clicked => { root.active-tab = 3; } }
                        HorizontalLayout {
                            padding-left: 8px; padding-right: 12px;
                            spacing: 7px; alignment: start;
                            Rectangle {
                                width: 16px;
                                IconDisplay {
                                    y: (parent.height - 15px) / 2;
                                    icon: IconSet.Route; stroke: root.active-tab == 3 ? Theme.teal : Theme.tab-inactive;
                                    size: 15px; stroke-width: 1.5; absolute-stroke-width: true;
                                }
                            }
                            Text {
                                text: "ROUTES"; color: root.active-tab == 3 ? Theme.teal : Theme.tab-inactive;
                                font-size: 13px; font-weight: 700;
                                vertical-alignment: center; letter-spacing: 0.8px;
                            }
                        }
                    }

                    settings-tab := Rectangle {
                        width: 140px; horizontal-stretch: 0;
                        Rectangle { y: parent.height - 2px; height: 2px; background: root.active-tab == 1 ? Theme.teal : transparent; }
                        TouchArea { clicked => { root.active-tab = 1; } }
                        HorizontalLayout {
                            padding-left: 8px; padding-right: 12px;
                            spacing: 7px; alignment: start;
                            Rectangle {
                                width: 16px;
                                IconDisplay {
                                    y: (parent.height - 15px) / 2;
                                    icon: IconSet.Settings; stroke: root.active-tab == 1 ? Theme.teal : Theme.tab-inactive;
                                    size: 15px; stroke-width: 1.5; absolute-stroke-width: true;
                                }
                            }
                            Text {
                                text: "SETTINGS"; color: root.active-tab == 1 ? Theme.teal : Theme.tab-inactive;
                                font-size: 13px; font-weight: 700;
                                vertical-alignment: center; letter-spacing: 0.8px;
                            }
                        }
                    }

                    Rectangle { horizontal-stretch: 1; }

                    // Connection indicator
                    Rectangle {
                        width: 18px; horizontal-stretch: 0;
                        Rectangle {
                            x: parent.width / 2 - 5px;
                            y: parent.height / 2 - 5px;
                            width: 10px; height: 10px; border-radius: 5px;
                            background: root.connected ? Theme.success-text : #3a4050;
                        }
                    }
                    Text {
                        horizontal-stretch: 0;
                        text: root.status-text;
                        color: root.connected ? #20A888 : #404860;
                        font-size: 15px; font-weight: 700;
                        vertical-alignment: center; letter-spacing: 0.3px;
                    }
                    if root.show-reconnect : reconnect-ta := TouchArea {
                        width: 110px; horizontal-stretch: 0;
                        clicked => { root.reconnect-clicked(); }
                        Rectangle {
                            y: (parent.height - 20px) / 2; height: 20px;
                            border-radius: 4px;
                            background: reconnect-ta.has-hover ? #1e3538 : #182628;
                            border-color: #2A8090; border-width: 1px;
                            Text {
                                text: "RECONNECT"; color: Theme.teal-accent;
                                font-size: 10px; font-weight: 700;
                                horizontal-alignment: center; vertical-alignment: center;
                                letter-spacing: 0.5px;
                            }
                        }
                    }
                }
            }

            // ── Tab content ───────────────────────────────────────────────────
            if root.active-tab == 0 : NavigationTab {
                position-text:    root.position-text;
                marker-text:      root.marker-text;
                marker-detected:  root.marker-detected;
                heading-text:     root.heading-text;
                distance-text:    root.distance-text;
                height-diff-text: root.height-diff-text;
                bearing-text:     root.bearing-text;

                hide-below        <=> root.hide-below;
                sticky-hide       <=> root.sticky-hide;
                inactive-ms       <=> root.inactive-ms;
                hide-on-inactive  <=> root.hide-on-inactive;

                ov-opacity        <=> root.ov-opacity;
                scale             <=> root.scale;
                locked            <=> root.locked;
                ov-opacity-label:     root.ov-opacity-label;
                scale-label:          root.scale-label;

                text-offset-x     <=> root.text-offset-x;
                text-offset-y     <=> root.text-offset-y;
                text-scale        <=> root.text-scale;
                text-scale-label:     root.text-scale-label;

                info-offset-x     <=> root.info-offset-x;
                info-offset-y     <=> root.info-offset-y;
                info-scale        <=> root.info-scale;
                info-hidden       <=> root.info-hidden;
                info-scale-label:     root.info-scale-label;

                copy-position  => { root.copy-position(); }
                input-marker   => { root.input-marker(); }
                copy-marker    => { root.copy-marker(); }
                paste-marker   => { root.paste-marker(); }
                save-position  => { root.save-position(); }
                save-marker    => { root.save-marker(); }

                hide-below-changed(v)       => { root.hide-below-changed(v); }
                sticky-hide-changed(v)      => { root.sticky-hide-changed(v); }
                inactive-ms-changed(v)      => { root.inactive-ms-changed(v); }
                hide-on-inactive-changed(v) => { root.hide-on-inactive-changed(v); }

                lock-toggled             => { root.lock-toggled(); }
                ov-opacity-changed(v)    => { root.ov-opacity-changed(v); }
                scale-changed(v)         => { root.scale-changed(v); }

                text-offset-x-changed(v) => { root.text-offset-x-changed(v); }
                text-offset-y-changed(v) => { root.text-offset-y-changed(v); }
                text-scale-changed(v)    => { root.text-scale-changed(v); }

                info-offset-x-changed(v) => { root.info-offset-x-changed(v); }
                info-offset-y-changed(v) => { root.info-offset-y-changed(v); }
                info-scale-changed(v)    => { root.info-scale-changed(v); }
                info-hidden-changed(v)   => { root.info-hidden-changed(v); }
            }
            if root.active-tab == 1 : SettingsTab { }
            if root.active-tab == 2 : MarkersTab { }
            if root.active-tab == 3 : RoutesTab { }

            Rectangle { vertical-stretch: 1; }
        }
    }

    // ── Nexus button ──────────────────────────────────────────────────────────
    nexus-ta := TouchArea {
        x: 17px;
        y: root.height - self.height - 4px;
        width: 150px;
        height: 40px;
        mouse-cursor: pointer;
        clicked => { root.open-nexus(); }
        opacity: nexus-ta.has-hover ? 0.75 : 1.0;
        animate opacity { duration: 100ms; }
        HorizontalLayout {
            spacing: 8px; alignment: center;
            Rectangle {
                width: 22px; horizontal-stretch: 0;
                Image {
                    y: (parent.height - 22px) / 2;
                    source: @image-url("../../assets/nexus.png");
                    width: 22px; height: 22px;
                    image-fit: contain;
                }
            }
            Text {
                text: "View mod on Nexus";
                color: #c8a060;
                font-size: 12px; font-weight: 700;
                vertical-alignment: center;
                horizontal-alignment: left;
                letter-spacing: 0.3px;
            }
        }
    }

    // ── Ko-fi button ──────────────────────────────────────────────────────────
    kofi-ta := TouchArea {
        x: root.width - self.width - 12px;
        y: root.height - self.height - 4px;
        width: 150px;
        height: 40px;
        mouse-cursor: pointer;
        clicked => { root.open-kofi(); }
        Rectangle {
            border-radius: 6px;
            opacity: kofi-ta.has-hover ? 0.85 : 1.0;
            animate opacity { duration: 100ms; }
            Image {
                source: @image-url("../../assets/kofi.png");
                width: parent.width;
                height: parent.height;
                image-fit: contain;
            }
        }
    }

    // ── App overlay backdrop (covers full window when dialog open) ────────────
    if root.input-dialog-open : Rectangle {
        x: 0; y: 0; width: root.width; height: root.height;
        z: 100;
        background: #000000bb;
        TouchArea {
            x: 0; y: 0; width: parent.width; height: parent.height;
            clicked => { root.input-dialog-close(); }
        }
    }

    // ── Input Marker dialog ─────────────────────────────────────────────────────────
    if root.input-dialog-open : InputMarkerDialog {
        z: 100;
        x: (root.width  - self.width)  / 2;
        y: (root.height - self.height) / 2;
        dialog-x           <=> root.dialog-x;
        dialog-y           <=> root.dialog-y;
        dialog-z           <=> root.dialog-z;
        dialog-x-error     <=> root.dialog-x-error;
        dialog-y-error     <=> root.dialog-y-error;
        dialog-z-error     <=> root.dialog-z-error;
        close()   => { root.input-dialog-close(); }
        confirm() => { root.input-dialog-confirm(); }
        paste()   => { root.input-dialog-paste(); }
        x-step(s) => { root.input-dialog-x-step(s); }
        y-step(s) => { root.input-dialog-y-step(s); }
        z-step(s) => { root.input-dialog-z-step(s); }
    }

    // ── Snackbar (z:200 → always above dialog overlay at z:100) ──────────────
    Snackbar {
        z: 200;
        x: root.width - self.width - 12px;
        y: 56px;
        open:     root.snack-open;
        message:  root.snack-message;
        is-error: root.snack-is-error;
    }
}
